generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  PATIENT
  CAREGIVER
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  passwordHash      String
  role              Role               @default(PATIENT)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  devices           Device[]
  alerts            Alert[]
  emergencyContacts EmergencyContact[]
}

model Device {
  id         String      @id @default(cuid())
  deviceId   String      @unique
  name       String?
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  ecgRecords EcgRecord[]
  alerts     Alert[]
}

model EcgRecord {
  id           String    @id @default(cuid())
  deviceId     String
  device       Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  timestamp    DateTime
  samplingRate Int       @default(250)

  lead1        Json
  lead2        Json
  lead3        Json

  heartRate    Int?
  hrv          Float?
  createdAt    DateTime  @default(now())

  alerts       Alert[]
}

model EmergencyContact {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String
  relation       String?
  phone          String?
  email          String?
  telegramChatId String?
  priority       Int      @default(1)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Alert {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceId     String
  device       Device        @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  ecgRecordId  String?
  ecgRecord    EcgRecord?    @relation(fields: [ecgRecordId], references: [id], onDelete: SetNull)

  type         AlertType
  severity     AlertSeverity
  message      String
  acknowledged Boolean       @default(false)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum AlertType {
  HIGH_HEART_RATE
  LOW_HEART_RATE
  LOW_HRV
  IRREGULAR_RHYTHM
  SIGNAL_LOSS
  DEVICE_OFFLINE
  GENERAL_RISK
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}